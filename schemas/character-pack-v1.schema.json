{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://startpoint-cn.local/schemas/character-pack-v1.schema.json",
  "title": "World Flipper CN character package manifest v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "logicalPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*(?:^|/)(?:[sS][tT][oO][rR][yY]|[wW][oO][rR][dD][sS]|[lL][oO][gG][iI][nN]|[eE][xX][pP][rR][eE][sS][sS][iI][oO][nN][sS]?)(?:/|$))[^/]+(?:/[^/]+)*$"
    },
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_path", "sha256", "size"],
      "properties": {
        "logical_path": {
          "$ref": "#/$defs/logicalPath"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "required": [
    "schema_version",
    "package_id",
    "character_id",
    "code_name",
    "package_version",
    "requires_client_base",
    "required_capabilities",
    "roots",
    "tables",
    "skills",
    "unique_condition",
    "qa",
    "snapshot"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "integer",
      "minimum": 0
    },
    "code_name": {
      "type": "string",
      "minLength": 1
    },
    "package_version": {
      "type": "string",
      "minLength": 1
    },
    "requires_client_base": {
      "type": "string",
      "minLength": 1
    },
    "required_capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "roots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["common", "medium", "android", "server"],
      "properties": {
        "common": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileEntry"
          }
        },
        "medium": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileEntry"
          }
        },
        "android": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileEntry"
          }
        },
        "server": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileEntry"
          }
        }
      }
    },
    "tables": {
      "type": "array"
    },
    "skills": {
      "type": "object"
    },
    "unique_condition": {
      "type": "object"
    },
    "qa": {
      "type": "object",
      "required": ["delivery_mode", "release_ready"],
      "properties": {
        "delivery_mode": {
          "type": "string",
          "enum": ["production", "runtime_test"]
        },
        "release_ready": {
          "type": "boolean"
        },
        "user_authorized_direct_real_test": {
          "type": "boolean"
        },
        "required_assets_total": {
          "type": "integer",
          "minimum": 0
        },
        "required_assets_present": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_input_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "snapshot": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "qa": {
            "properties": {
              "delivery_mode": {
                "const": "production"
              }
            },
            "required": ["delivery_mode"]
          }
        }
      },
      "then": {
        "properties": {
          "qa": {
            "required": [
              "delivery_mode",
              "release_ready",
              "required_assets_total",
              "required_assets_present",
              "workspace_input_sha256"
            ],
            "properties": {
              "release_ready": {
                "const": true
              },
              "required_assets_total": {
                "const": 37
              },
              "required_assets_present": {
                "const": 37
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "qa": {
            "properties": {
              "delivery_mode": {
                "const": "runtime_test"
              }
            },
            "required": ["delivery_mode"]
          }
        }
      },
      "then": {
        "properties": {
          "qa": {
            "required": [
              "delivery_mode",
              "release_ready",
              "user_authorized_direct_real_test"
            ],
            "properties": {
              "release_ready": {
                "const": false
              },
              "user_authorized_direct_real_test": {
                "const": true
              }
            }
          }
        }
      }
    }
  ]
}
